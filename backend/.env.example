# Data provider configuration for the TON Wallet Intelligence Dashboard.
# Copy to backend/.env and fill in values to enable real providers.
# Leave DATA_MODE=mock (the default) to run entirely on bundled mock data.

# mock | real
DATA_MODE=mock

# mainnet | testnet. Scopes raw TON wallet identities and the guarded live
# TonAPI path. User-friendly addresses retain their encoded network scope.
TON_NETWORK=mainnet
# Local TVM execution uses proof-checked liteserver account state. Trust level 1
# verifies shard/account proofs to the selected head; level 0 additionally
# verifies the masterchain proof link from the pinned official checkpoint.
TON_LITECLIENT_TRUST_LEVEL=1
TON_LITECLIENT_TIMEOUT_SECONDS=20
TONCONNECT_EXPECTED_DOMAIN=127.0.0.1:5173
TONCONNECT_PROOF_TTL_SECONDS=900

# Optional SQLite SQLAlchemy URL. Unset defaults to backend/ton_check.db.
# TON_CHECK_DB_URL=sqlite:///./ton_check.db

# GeckoTerminal public API (no key required). Used for real pool/token data.
GECKOTERMINAL_BASE_URL=https://api.geckoterminal.com/api/v2

# TON indexer (e.g. TonAPI / Toncenter). Both required for real TON data.
TON_API_BASE_URL=
TON_API_KEY=

# TonAPI account/jetton previews. Leave the base URL empty to select the
# official mainnet/testnet host from TON_NETWORK. An explicit official host
# must match TON_NETWORK. API key is optional; public mode may be rate-limited.
# A configured API key requires an HTTPS base URL.
TONAPI_BASE_URL=
TONAPI_API_KEY=

# STON.fi pool previews.
STONFI_BASE_URL=https://api.ston.fi

# Bitquery (historical DEX trades). API key required for real trade data.
BITQUERY_API_URL=
BITQUERY_API_KEY=

# Wallet activity ingestion provider selection.
# mock keeps deterministic fixtures active. tonapi, ton_provider, stonfi, and
# bitquery expose limited/scaffold coverage in DATA_MODE=real. Only tonapi with
# the explicit live guard performs live wallet-activity ingestion.
WALLET_ACTIVITY_PROVIDER=mock

# Guarded live wallet activity. Requires DATA_MODE=real and
# WALLET_ACTIVITY_PROVIDER=tonapi. The guarded live path fetches TonAPI native
# TON balance snapshots, account jetton balance snapshots, an ordered account
# transaction-history timeline, TON/jetton transfer history, and DEX swaps from
# account events. Analytics consume persisted runs separately; the live guard
# does not prove ownership or complete history.
WALLET_ACTIVITY_LIVE_ENABLED=false
WALLET_ACTIVITY_LIVE_JETTON_LIMIT=100
# TonAPI live transaction-history page size, clamped to 1..1000.
WALLET_ACTIVITY_LIVE_TX_LIMIT=100
# Maximum transaction pages attempted for one bounded ingestion run, clamped
# to 1..100. Reaching this cap is persisted as incomplete evidence.
WALLET_ACTIVITY_LIVE_TX_MAX_PAGES=10
# Shared TonAPI account-event page size/cap for provider-derived transfer and
# swap display rows. Event actions are not authoritative protocol logic.
WALLET_ACTIVITY_LIVE_EVENT_LIMIT=100
WALLET_ACTIVITY_LIVE_EVENT_MAX_PAGES=10
